rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function isAuthenticated() {
      return request.auth != null;
    }

    function hasEmail() {
      return isAuthenticated() && request.auth.token.email != null;
    }

    function authEmail() {
      return request.auth.token.email;
    }

    function isGoogleUser() {
      return isAuthenticated()
             && request.auth.token.firebase != null
             && request.auth.token.firebase.sign_in_provider == 'google.com';
    }

    function isAllowedUser() {
      return hasEmail()
             && exists(/databases/$(database)/documents/allowedUsers/$(authEmail()));
    }

    function userRoles() {
      return get(/databases/$(database)/documents/allowedUsers/$(authEmail())).data;
    }

    function hasRole(role) {
      return isAllowedUser() && userRoles().get(role, false) == true;
    }

    function isAdministration() {
      return hasRole('administration') && isGoogleUser();
    }

    function isAdminFlux() {
      return hasRole('admin_flux') && isGoogleUser();
    }

    function isParticipants() {
      return hasRole('participants') && isGoogleUser();
    }

    function hasResultUser() {
      return isAuthenticated()
             && exists(/databases/$(database)/documents/allowedResultUsers/$(request.auth.uid));
    }

    function resultRoles() {
      return get(/databases/$(database)/documents/allowedResultUsers/$(request.auth.uid)).data;
    }

    function hasResultRole(role) {
      return hasResultUser() && resultRoles().get(role, false) == true;
    }

    function hasGrantedResultAccess() {
      return hasResultRole('results_start') || hasResultRole('results_finish');
    }

    function hasTvAccess() {
      return hasResultRole('tv');
    }

    function canManageStation(stationId) {
      return (stationId == 'start' && hasResultRole('results_start'))
             || (stationId == 'finish' && hasResultRole('results_finish'));
    }

    function currentStationDocId(stationId) {
      return stationId == 'start'
        ? 'currentStart'
        : stationId == 'finish'
          ? 'currentFinish'
          : '__invalid__';
    }

    function currentStationExists(docId) {
      return exists(/databases/$(database)/documents/currentStations/$(docId));
    }

    function currentStationOwnedByRequester(docId) {
      return currentStationExists(docId)
             && get(/databases/$(database)/documents/currentStations/$(docId)).data.assignedUid == request.auth.uid;
    }

    function ownsCurrentStation(stationId) {
      return currentStationOwnedByRequester(currentStationDocId(stationId));
    }

    function canReadCurrentStation(docId) {
      return isAdministration()
             || currentStationOwnedByRequester(docId)
             || (currentStationMatchesRole(docId) && !currentStationExists(docId));
    }

    function currentStationMatchesRole(docId) {
      return (docId == 'currentStart' && hasResultRole('results_start'))
             || (docId == 'currentFinish' && hasResultRole('results_finish'));
    }

    function validCurrentStationPayload(docId) {
      return request.resource.data.assignedUid == request.auth.uid
             && request.resource.data.station == (
               docId == 'currentStart'
                 ? 'start'
                 : docId == 'currentFinish'
                   ? 'finish'
                   : '__invalid__'
             );
    }

    function canClaimCurrentStation(docId) {
      return currentStationMatchesRole(docId)
             && validCurrentStationPayload(docId)
             && (!currentStationExists(docId) || currentStationOwnedByRequester(docId));
    }

    function hasOnlyTvRole(data) {
      return data.get('tv', false) == true
             && data.get('results_start', false) == false
             && data.get('results_finish', false) == false;
    }

    function hasOnlyResultsRoles(data) {
      return data.get('tv', false) == false;
    }

    function validLightRoleCombination(data) {
      return hasOnlyTvRole(data) || hasOnlyResultsRoles(data);
    }

    match /allowedUsers/{email} {
      allow get: if hasEmail() && email == authEmail();
      allow list: if isAdministration();
      allow create, update, delete: if isAdministration();
    }

    match /accessRequests/{email} {
      allow create, update: if hasEmail()
                            && email == authEmail()
                            && request.resource.data.email == authEmail()
                            && request.resource.data.status == 'pending';
      allow get: if isAdministration() || (hasEmail() && email == authEmail());
      allow list: if isAdministration();
      allow update, delete: if isAdministration();
    }

    match /allowedResultUsers/{uid} {
      allow get: if isAdministration() || (isAuthenticated() && uid == request.auth.uid);
      allow list: if isAdministration();
      allow create, update: if isAdministration() && validLightRoleCombination(request.resource.data);
      allow delete: if isAdministration();
    }

    match /resultAccessRequests/{uid} {
      allow create: if (isAuthenticated()
                        && uid == request.auth.uid
                        && request.resource.data.uid == request.auth.uid
                        && request.resource.data.status == 'pending')
                    || isAdministration();
      allow update: if (isAuthenticated()
                        && uid == request.auth.uid
                        && request.resource.data.uid == request.auth.uid
                        && request.resource.data.status == 'pending')
                    || isAdministration();
      allow get: if isAdministration() || (isAuthenticated() && uid == request.auth.uid);
      allow list: if isAdministration();
      allow delete: if isAdministration();
    }

    match /resultStations/{stationId} {
      allow read: if isAdministration() || hasGrantedResultAccess() || hasTvAccess();
      allow create, update: if isAdministration() || (canManageStation(stationId) && ownsCurrentStation(stationId));
      allow delete: if isAdministration();
    }

    match /currentStations/{docId} {
      allow get: if canReadCurrentStation(docId);
      allow list: if isAdministration();
      allow create, update: if isAdministration() || canClaimCurrentStation(docId);
      allow delete: if isAdministration() || currentStationOwnedByRequester(docId);
    }

    match /currentCompetitor/{docId} {
      allow read: if isAdministration() || hasGrantedResultAccess() || hasTvAccess();
      allow create, update: if isAdministration()
                            || (docId == 'current'
                                && hasResultRole('results_start')
                                && ownsCurrentStation('start'));
      allow delete: if isAdministration()
                    || (docId == 'current'
                        && ((hasResultRole('results_start') && ownsCurrentStation('start'))
                            || (hasResultRole('results_finish') && ownsCurrentStation('finish'))));
    }

    match /resultEvents/{eventId} {
      allow read: if isAdministration() || hasGrantedResultAccess() || hasTvAccess();
      allow create: if isAdministration() || hasGrantedResultAccess();
      allow update: if isAdministration();
      allow delete: if isAdministration();
    }

    match /resultRuns/{runId} {
      allow read: if isAllowedUser() || hasGrantedResultAccess() || hasTvAccess();
      allow create, update: if isAdministration() || hasGrantedResultAccess();
      allow delete: if isAdministration();
    }

    match /clockChecks/{uid} {
      allow read, write: if isAuthenticated() && uid == request.auth.uid;
    }

    match /config/streams {
      allow read: if isAllowedUser() || hasTvAccess();
      allow write: if isAdminFlux() || isAdministration();
    }

    match /participants/{participantId} {
      allow read: if isAllowedUser() || hasGrantedResultAccess();
      allow write: if isParticipants() || isAdministration();
    }

    match /races/{raceId} {
      allow read, write: if false;

      match /results/{resultId} {
        allow read, write: if false;
      }
    }
  }
}
