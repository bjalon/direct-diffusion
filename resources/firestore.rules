rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function isAuthenticated() {
      return request.auth != null;
    }

    function hasEmail() {
      return isAuthenticated() && request.auth.token.email != null;
    }

    function authEmail() {
      return request.auth.token.email;
    }

    function isGoogleUser() {
      return isAuthenticated()
             && request.auth.token.firebase != null
             && request.auth.token.firebase.sign_in_provider == 'google.com';
    }

    function isGlobalAllowedUser() {
      return hasEmail()
             && exists(/databases/$(database)/documents/allowedUsers/$(authEmail()));
    }

    function globalRoles() {
      return get(/databases/$(database)/documents/allowedUsers/$(authEmail())).data;
    }

    function hasGlobalRole(role) {
      return isGlobalAllowedUser() && globalRoles().get(role, false) == true;
    }

    function isEventsAdministration() {
      return hasGlobalRole('admin_events') && isGoogleUser();
    }

    function isEventAllowedUser(eventId) {
      return hasEmail()
             && exists(/databases/$(database)/documents/events/$(eventId)/allowedUsers/$(authEmail()));
    }

    function eventUserRoles(eventId) {
      return get(/databases/$(database)/documents/events/$(eventId)/allowedUsers/$(authEmail())).data;
    }

    function hasEventRole(eventId, role) {
      return isEventAllowedUser(eventId) && eventUserRoles(eventId).get(role, false) == true;
    }

    function isEventAdministration(eventId) {
      return isEventsAdministration()
             || (hasEventRole(eventId, 'administration') && isGoogleUser());
    }

    function isEventAdminFlux(eventId) {
      return hasEventRole(eventId, 'admin_flux') && isGoogleUser();
    }

    function isEventParticipants(eventId) {
      return hasEventRole(eventId, 'participants') && isGoogleUser();
    }

    function canReadProtectedEventData(eventId) {
      return isEventAdministration(eventId) || isEventAllowedUser(eventId);
    }

    function hasResultUser(eventId) {
      return isAuthenticated()
             && exists(/databases/$(database)/documents/events/$(eventId)/allowedResultUsers/$(request.auth.uid));
    }

    function resultRoles(eventId) {
      return get(/databases/$(database)/documents/events/$(eventId)/allowedResultUsers/$(request.auth.uid)).data;
    }

    function hasResultRole(eventId, role) {
      return hasResultUser(eventId) && resultRoles(eventId).get(role, false) == true;
    }

    function hasGrantedResultAccess(eventId) {
      return hasResultRole(eventId, 'results_start') || hasResultRole(eventId, 'results_finish');
    }

    function hasTvAccess(eventId) {
      return hasResultRole(eventId, 'tv');
    }

    function hasFootballUser(eventId) {
      return isAuthenticated()
             && exists(/databases/$(database)/documents/events/$(eventId)/allowedFootballUsers/$(request.auth.uid));
    }

    function footballRoles(eventId) {
      return get(/databases/$(database)/documents/events/$(eventId)/allowedFootballUsers/$(request.auth.uid)).data;
    }

    function hasFootballRole(eventId, role) {
      return hasFootballUser(eventId) && footballRoles(eventId).get(role, false) == true;
    }

    function hasFootballTvAccess(eventId) {
      return hasFootballRole(eventId, 'tv');
    }

    function hasFootballScoreAccess(eventId) {
      return hasFootballRole(eventId, 'score');
    }

    function hasFootballCommentatorAccess(eventId) {
      return hasFootballRole(eventId, 'commentator');
    }

    function canManageStation(eventId, stationId) {
      return (stationId == 'start' && hasResultRole(eventId, 'results_start'))
             || (stationId == 'finish' && hasResultRole(eventId, 'results_finish'));
    }

    function currentStationDocId(stationId) {
      return stationId == 'start'
        ? 'currentStart'
        : stationId == 'finish'
          ? 'currentFinish'
          : '__invalid__';
    }

    function currentStationPath(eventId, docId) {
      return /databases/$(database)/documents/events/$(eventId)/currentStations/$(docId);
    }

    function currentStationExists(eventId, docId) {
      return exists(currentStationPath(eventId, docId));
    }

    function currentStationOwnedByRequester(eventId, docId) {
      return currentStationExists(eventId, docId)
             && get(currentStationPath(eventId, docId)).data.assignedUid == request.auth.uid;
    }

    function ownsCurrentStation(eventId, stationId) {
      return currentStationOwnedByRequester(eventId, currentStationDocId(stationId));
    }

    function currentStationMatchesRole(eventId, docId) {
      return (docId == 'currentStart' && hasResultRole(eventId, 'results_start'))
             || (docId == 'currentFinish' && hasResultRole(eventId, 'results_finish'));
    }

    function canReadCurrentStation(eventId, docId) {
      return isEventAdministration(eventId) || currentStationMatchesRole(eventId, docId);
    }

    function validCurrentStationPayload(docId) {
      return request.resource.data.assignedUid == request.auth.uid
             && request.resource.data.station == (
               docId == 'currentStart'
                 ? 'start'
                 : docId == 'currentFinish'
                   ? 'finish'
                   : '__invalid__'
             );
    }

    function canClaimCurrentStation(eventId, docId) {
      return currentStationMatchesRole(eventId, docId)
             && validCurrentStationPayload(docId)
             && (!currentStationExists(eventId, docId) || currentStationOwnedByRequester(eventId, docId));
    }

    function currentCompetitorPath(eventId) {
      return /databases/$(database)/documents/events/$(eventId)/currentCompetitor/current;
    }

    function currentCompetitorExists(eventId) {
      return exists(currentCompetitorPath(eventId));
    }

    function currentCompetitorData(eventId) {
      return get(currentCompetitorPath(eventId)).data;
    }

    function currentCompetitorMatchesRequest(eventId) {
      return currentCompetitorExists(eventId)
             && request.resource.data.runId == currentCompetitorData(eventId).runId
             && request.resource.data.startId == currentCompetitorData(eventId).startId;
    }

    function hasLocalStartForCurrentCompetitor(eventId) {
      return currentCompetitorExists(eventId)
             && currentCompetitorData(eventId).latestStartAtClientMs != null
             && currentCompetitorData(eventId).latestStartClickId != null;
    }

    function canFinishCurrentCompetitor(eventId) {
      return currentCompetitorMatchesRequest(eventId)
             && hasLocalStartForCurrentCompetitor(eventId);
    }

    function canAbandonCurrentCompetitor(eventId) {
      return canFinishCurrentCompetitor(eventId)
             && currentCompetitorData(eventId).status == 'running';
    }

    function canRecoverStartEventFromFinish(eventId) {
      return ownsCurrentStation(eventId, 'finish')
             && currentCompetitorExists(eventId)
             && request.resource.data.clickId == currentCompetitorData(eventId).latestStartClickId
             && canFinishCurrentCompetitor(eventId);
    }

    function canCreateResultEvent(eventId) {
      return (
               request.resource.data.type == 'start'
               && request.resource.data.station == 'start'
               && canRecoverStartEventFromFinish(eventId)
               && request.resource.data.actorUid == currentCompetitorData(eventId).selectedByUid
             )
             || (
               request.resource.data.actorUid == request.auth.uid
               && (
                 (request.resource.data.type == 'start'
                  && request.resource.data.station == 'start'
                  && ownsCurrentStation(eventId, 'start'))
                 || (request.resource.data.type == 'finish'
                     && request.resource.data.station == 'finish'
                     && ownsCurrentStation(eventId, 'finish')
                     && canFinishCurrentCompetitor(eventId))
                 || (request.resource.data.type == 'abandon'
                     && request.resource.data.station == 'finish'
                     && ownsCurrentStation(eventId, 'finish')
                     && canAbandonCurrentCompetitor(eventId))
               )
             );
    }

    function canCreateResultRun(eventId) {
      return ownsCurrentStation(eventId, 'start');
    }

    function canUpdateResultRunFromFinish(eventId) {
      return ownsCurrentStation(eventId, 'finish')
             && (
               (request.resource.data.status == 'finished' && canFinishCurrentCompetitor(eventId))
               || (request.resource.data.status == 'abandoned' && canAbandonCurrentCompetitor(eventId))
             );
    }

    function canUpdateResultRun(eventId) {
      return ownsCurrentStation(eventId, 'start')
             || canUpdateResultRunFromFinish(eventId);
    }

    function hasOnlyTvRole(data) {
      return data.get('tv', false) == true
             && data.get('results_start', false) == false
             && data.get('results_finish', false) == false;
    }

    function hasOnlyResultsRoles(data) {
      return data.get('tv', false) == false;
    }

    function validLightRoleCombination(data) {
      return hasOnlyTvRole(data) || hasOnlyResultsRoles(data);
    }

    function validFootballRoleCombination(data) {
      return (data.get('tv', false) == true
              && data.get('score', false) == false
              && data.get('commentator', false) == false)
             || data.get('tv', false) == false;
    }

    function footballScoreStationPath(eventId, stationId) {
      return /databases/$(database)/documents/events/$(eventId)/footballStations/$(stationId);
    }

    function footballScoreStationExists(eventId, stationId) {
      return exists(footballScoreStationPath(eventId, stationId));
    }

    function footballScoreStationOwnedByRequester(eventId, stationId) {
      return footballScoreStationExists(eventId, stationId)
             && get(footballScoreStationPath(eventId, stationId)).data.assignedUid == request.auth.uid;
    }

    function canClaimFootballScoreStation(eventId, stationId) {
      return hasFootballScoreAccess(eventId)
             && request.resource.data.assignedUid == request.auth.uid
             && request.resource.data.station == 'score'
             && request.resource.data.matchId == stationId
             && (!footballScoreStationExists(eventId, stationId) || footballScoreStationOwnedByRequester(eventId, stationId));
    }

    function canCreateFootballEvent(eventId) {
      return request.resource.data.matchId != null
             && request.resource.data.createdByUid == request.auth.uid
             && (
               (request.resource.data.type == 'goal'
                && (isEventAdministration(eventId) || footballScoreStationOwnedByRequester(eventId, request.resource.data.matchId)))
               || (request.resource.data.type == 'highlight'
                   && (isEventAdministration(eventId)
                       || footballScoreStationOwnedByRequester(eventId, request.resource.data.matchId)
                       || hasFootballCommentatorAccess(eventId)))
             );
    }

    match /allowedUsers/{email} {
      allow get: if hasEmail() && email == authEmail();
      allow list: if isEventsAdministration();
      allow create, update, delete: if isEventsAdministration();
    }

    match /events/{eventId} {
      allow read: if isEventsAdministration()
                  || resource.data.published == true
                  || isEventAllowedUser(eventId)
                  || hasResultUser(eventId)
                  || hasFootballUser(eventId);
      allow create, delete: if isEventsAdministration();
      allow update: if isEventsAdministration()
                    && request.resource.data.type == resource.data.type;

      match /allowedUsers/{email} {
        allow get: if isEventsAdministration() || isEventAdministration(eventId) || (hasEmail() && email == authEmail());
        allow list: if isEventsAdministration() || isEventAdministration(eventId);
        allow create, update, delete: if isEventsAdministration() || isEventAdministration(eventId);
      }

      match /accessRequests/{email} {
        allow create, update: if hasEmail()
                              && email == authEmail()
                              && request.resource.data.email == authEmail()
                              && request.resource.data.status == 'pending';
        allow get: if isEventsAdministration() || isEventAdministration(eventId) || (hasEmail() && email == authEmail());
        allow list: if isEventsAdministration() || isEventAdministration(eventId);
        allow update, delete: if isEventsAdministration() || isEventAdministration(eventId);
      }

      match /allowedResultUsers/{uid} {
        allow get: if isEventAdministration(eventId) || (isAuthenticated() && uid == request.auth.uid);
        allow list: if isEventAdministration(eventId);
        allow create, update: if isEventAdministration(eventId) && validLightRoleCombination(request.resource.data);
        allow delete: if isEventAdministration(eventId);
      }

      match /allowedFootballUsers/{uid} {
        allow get: if isEventAdministration(eventId) || (isAuthenticated() && uid == request.auth.uid);
        allow list: if isEventAdministration(eventId);
        allow create, update: if isEventAdministration(eventId) && validFootballRoleCombination(request.resource.data);
        allow delete: if isEventAdministration(eventId);
      }

      match /resultAccessRequests/{uid} {
        allow create: if (isAuthenticated()
                          && uid == request.auth.uid
                          && request.resource.data.uid == request.auth.uid
                          && request.resource.data.status == 'pending')
                      || isEventAdministration(eventId);
        allow update: if (isAuthenticated()
                          && uid == request.auth.uid
                          && request.resource.data.uid == request.auth.uid
                          && request.resource.data.status == 'pending')
                      || isEventAdministration(eventId);
        allow get: if isEventAdministration(eventId) || (isAuthenticated() && uid == request.auth.uid);
        allow list: if isEventAdministration(eventId);
        allow delete: if isEventAdministration(eventId);
      }

      match /footballAccessRequests/{uid} {
        allow create: if (isAuthenticated()
                          && uid == request.auth.uid
                          && request.resource.data.uid == request.auth.uid
                          && request.resource.data.status == 'pending')
                      || isEventAdministration(eventId);
        allow update: if (isAuthenticated()
                          && uid == request.auth.uid
                          && request.resource.data.uid == request.auth.uid
                          && request.resource.data.status == 'pending')
                      || isEventAdministration(eventId);
        allow get: if isEventAdministration(eventId) || (isAuthenticated() && uid == request.auth.uid);
        allow list: if isEventAdministration(eventId);
        allow delete: if isEventAdministration(eventId);
      }

      match /resultStations/{stationId} {
        allow read: if isEventAdministration(eventId) || hasGrantedResultAccess(eventId) || hasTvAccess(eventId);
        allow create, update: if isEventAdministration(eventId) || (canManageStation(eventId, stationId) && ownsCurrentStation(eventId, stationId));
        allow delete: if isEventAdministration(eventId);
      }

      match /currentStations/{docId} {
        allow get: if canReadCurrentStation(eventId, docId);
        allow list: if isEventAdministration(eventId);
        allow create, update: if isEventAdministration(eventId) || canClaimCurrentStation(eventId, docId);
        allow delete: if isEventAdministration(eventId) || currentStationOwnedByRequester(eventId, docId);
      }

      match /currentCompetitor/{docId} {
        allow read: if isEventAdministration(eventId) || hasGrantedResultAccess(eventId) || hasTvAccess(eventId);
        allow create, update: if isEventAdministration(eventId)
                              || (docId == 'current'
                                  && hasResultRole(eventId, 'results_start')
                                  && ownsCurrentStation(eventId, 'start'));
        allow delete: if isEventAdministration(eventId)
                      || (docId == 'current'
                          && ((hasResultRole(eventId, 'results_start') && ownsCurrentStation(eventId, 'start'))
                              || (hasResultRole(eventId, 'results_finish') && ownsCurrentStation(eventId, 'finish'))));
      }

      match /resultEvents/{eventDocId} {
        allow read: if isEventAdministration(eventId) || hasGrantedResultAccess(eventId) || hasTvAccess(eventId);
        allow create: if canCreateResultEvent(eventId);
        allow update: if isEventAdministration(eventId);
        allow delete: if isEventAdministration(eventId);
      }

      match /resultRuns/{runId} {
        allow read: if canReadProtectedEventData(eventId) || hasGrantedResultAccess(eventId) || hasTvAccess(eventId);
        allow create: if canCreateResultRun(eventId);
        allow update: if canUpdateResultRun(eventId);
        allow delete: if isEventAdministration(eventId);
      }

      match /clockChecks/{uid} {
        allow read, write: if isAuthenticated() && uid == request.auth.uid;
      }

      match /footballStations/{docId} {
        allow get: if isEventAdministration(eventId)
                   || hasFootballScoreAccess(eventId)
                   || hasFootballCommentatorAccess(eventId);
        allow list: if isEventAdministration(eventId) || hasFootballScoreAccess(eventId);
        allow create, update: if canClaimFootballScoreStation(eventId, docId)
                              || isEventAdministration(eventId);
        allow delete: if isEventAdministration(eventId)
                      || footballScoreStationOwnedByRequester(eventId, docId);
      }

      match /footballMatches/{matchId} {
        allow read: if canReadProtectedEventData(eventId) || hasFootballUser(eventId);
        allow create, update, delete: if isEventAdministration(eventId);
      }

      match /footballEvents/{eventDocId} {
        allow read: if canReadProtectedEventData(eventId) || hasFootballUser(eventId);
        allow create: if canCreateFootballEvent(eventId);
        allow update, delete: if isEventAdministration(eventId);
      }

      match /config/{docId} {
        allow read: if canReadProtectedEventData(eventId) || hasTvAccess(eventId) || hasFootballTvAccess(eventId);
        allow write: if isEventAdminFlux(eventId) || isEventAdministration(eventId);
      }

      match /participants/{participantId} {
        allow read: if canReadProtectedEventData(eventId) || hasGrantedResultAccess(eventId) || hasFootballUser(eventId);
        allow write: if isEventParticipants(eventId) || isEventAdministration(eventId);
      }
    }
  }
}
